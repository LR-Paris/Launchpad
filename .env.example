# Session secret — must be at least 32 characters
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Backend port
PORT=3001

# Node environment
NODE_ENV=development

# Set to true only if serving over HTTPS
COOKIE_SECURE=false

# Shops are served via path-based routing (e.g. domain.com/shopname)
# No BASE_DOMAIN or DNS configuration is needed — nginx proxies
# each shop's path to its container port automatically.

# Required: set to your actual domain
FRONTEND_URL=https://yourdomain.com
BASE_DOMAIN=yourdomain.com

# Required: absolute path to this project on the host (used by backend to manage shop containers)
HOST_PROJECT_DIR=/path/to/Launchpad

# Mailgun email integration
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.yourdomain.com
FALLBACK_ADMIN_EMAIL=admin@yourdomain.com
